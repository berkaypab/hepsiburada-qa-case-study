{
	"name": "hepsiburada-qa-automation",
	"version": "1.0.0",
	"description": "Playwright TypeScript testing framework built for the QA Assignment automation.",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"setup": "npm ci && playwright install",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:api": "playwright test --project=api",
		"test:e2e": "playwright test --project=chrome",
		"test:headed": "playwright test --headed",
		"test:debug": "playwright test --debug",
		"test:trace": "playwright test --trace on",
		"test:regression": "playwright test --grep @regression",
		"test:customer": "playwright test --grep @customer",
		"test:report": "playwright show-report reports/playwright-report",
		"codegen": "playwright codegen"
	},
	"keywords": [],
	"devDependencies": {
		"@eslint/js": "^9.24.0",
		"@playwright/test": "^1.58.2",
		"@types/node": "^24.0.3",
		"@typescript-eslint/eslint-plugin": "^8.29.1",
		"@typescript-eslint/parser": "^8.29.1",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-playwright": "^2.9.0",
		"eslint-plugin-prettier": "^5.2.6",
		"globals": "^16.0.0",
		"prettier": "^3.5.3",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.29.1"
	},
	"dependencies": {
		"dotenv": "^16.4.7"
	}
}